# ============================================
# HornbillSentinel Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- JWT Configuration -----
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# ----- Session Configuration -----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ----- Security Settings -----
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=7200000

# ----- Gmail / Email Configuration -----
# Option A: Simple App Password auth (recommended for development)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option B: OAuth2 auth (recommended for production)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Sender display address (falls back to GMAIL_USER if not set)
FROM_EMAIL=

# ----- Frontend URL (used for CORS + password reset links) -----
FRONTEND_URL=http://localhost:3000

# ----- Server Configuration -----
PORT=5001
NODE_ENV=development

# ----- MongoDB -----
MONGO_URI=mongodb://localhost:27017/digital_type_assessment
TEST_MONGO_URI=mongodb://localhost:27017/digital_type_assessment_test
